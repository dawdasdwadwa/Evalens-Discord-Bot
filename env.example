# Секреты — только в Railway Variables, никогда не коммитить в этот файл!
DISCORD_TOKEN=

# --- роли верификации (обязательно заполнить) ---
VERIFIED_ROLE_ID=1397851164279701547
UNVERIFIED_ROLE_ID=1502733657645908199

# --- всё ниже опционально: значения по умолчанию уже зашиты в settings.py под новый сервер ---


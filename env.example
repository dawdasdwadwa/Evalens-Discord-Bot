# Через запятую, без пробелов вокруг запятых обязательно не требуется

# Общий стафф — доступ к /ban /mute /server и т.д., а также к тикетам «Жалоба на игрока»
# STAFF_ROLE_IDS=1494820871821459517

# Кому доступна /profile
# PROFILE_ROLE_IDS=1397851164279701547

# Кто видит и ведёт тикеты «Жалоба на персонал» (НЕ весь STAFF_ROLE_IDS, а именно эти роли);
# они же пингуются при создании такого тикета
# STAFF_REPORT_ACCESS_ROLE_IDS=1397851164292415509,1397851164292415508

# Кто может НАВСЕГДА удалять тикеты (кнопка «Удалить тикет») — действует на тикеты любого типа
# TICKET_DELETE_ROLE_IDS=1397851164292415509,1397851164292415508

# Роли, теряющие доступ к тикету при закрытии (кроме автора). Пусто = весь стафф
# по-прежнему видит закрытые тикеты
# TICKET_CLOSED_HIDDEN_ROLE_IDS=

# Папка для temp_bans.json и ticket_history.json. На Railway укажи путь,
# на который смонтирован Volume (например /data) — тогда эти файлы переживут редеплой.
# Без Volume можно не задавать — файлы будут лежать рядом с кодом, но сбросятся при редеплое.
# DATA_DIR=/data

# Роли с доступом к тикету «Жалоба на игрока», которых не нужно пинговать при его создании
# TICKET_NO_PING_ROLE_IDS=

# VERIFICATION_TITLE=Верификация
# VERIFICATION_DESCRIPTION=Нажмите на кнопку ниже, чтобы подтвердить, что вы не бот, и получить доступ к серверу.
# VERIFICATION_BUTTON_LABEL=Верифицироваться
# VERIFICATION_IMAGE_URL=https://i.postimg.cc/T2mLYLtV/image.png
